# MongoDB connection string
# Local (without Docker): mongodb://localhost:27017/paperview
# Docker Compose:         set automatically from MONGO_USERNAME / MONGO_PASSWORD below
# Atlas:                  mongodb+srv://user:password@cluster.mongodb.net/paperview
MONGODB_URI=mongodb://localhost:27017/paperview

# MongoDB credentials (used by Docker Compose)
MONGO_USERNAME=paperview
MONGO_PASSWORD=replace-with-a-strong-random-password

# A long, random secret used to sign auth cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-a-long-random-string-of-at-least-32-characters

# Bootstrap admin account (created automatically on first startup)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-on-first-login
