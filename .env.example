# MongoDB connection string
# Local (ohne Docker): mongodb://localhost:27017/document-comments  (oder 27018 wenn Docker läuft)
# Docker Compose:      mongodb://mongodb:27017/document-comments  (wird automatisch gesetzt)
# Atlas:               mongodb+srv://user:password@cluster.mongodb.net/document-comments
MONGODB_URI=mongodb://localhost:27017/document-comments

# The single global password to access the document
DOC_PASSWORD=your-secret-password-here

# A long, random secret used to sign auth cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-a-long-random-string-of-at-least-32-characters
