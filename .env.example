# MongoDB connection string
# Local (without Docker): mongodb://localhost:27017/paperview
# Docker Compose:         set automatically from MONGO_USERNAME / MONGO_PASSWORD below
# Atlas:                  mongodb+srv://user:password@cluster.mongodb.net/paperview
MONGODB_URI=mongodb://localhost:27017/paperview

# MongoDB credentials (used by Docker Compose)
MONGO_USERNAME=paperview
MONGO_PASSWORD=replace-with-a-strong-random-password

# A long, random secret used to sign auth cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-a-long-random-string-of-at-least-32-characters

# Bootstrap admin account (created automatically on first startup)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-on-first-login

# ── Reverse Proxy / Tunnel (optional) ────────────────────────────────
# When running behind a reverse proxy, CDN, or tunnel (e.g. Cloudflare
# Tunnel, Nginx, Traefik, Caddy), ensure your proxy forwards these headers:
#   Host                → the public hostname (e.g. shareables.example.com)
#   X-Forwarded-Proto   → https
#   X-Forwarded-For     → client IP
#
# No extra env vars are needed — the app reads the forwarded headers
# automatically via `experimental.trustHostHeader` in next.config.ts
# and the `buildPublicUrl()` helper in proxy.ts.
#
# HOSTNAME=0.0.0.0 in the Dockerfile is the bind address only.
# With trustHostHeader enabled, the Host header from the proxy is used
# for URL construction and routing — not HOSTNAME.
